<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- INTENTIONAL: zero <uses-permission> entries.
         PRIV-01 / PRIV-03 require zero network egress. PRIV-02 requires no auth.
         Adding INTERNET, ACCESS_NETWORK_STATE, READ_PHONE_STATE etc. is forbidden in Phase 1.
         Verified by LiteRTNoNetworkTest and `./gradlew lint`. -->

    <application
        android:name=".MainApplication"
        android:allowBackup="false"
        android:icon="@android:drawable/sym_def_app_icon"
        android:label="SafeGlow Edge"
        android:roundIcon="@android:drawable/sym_def_app_icon"
        android:supportsRtl="true"
        android:theme="@android:style/Theme.Material.Light.NoActionBar.Fullscreen">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@android:style/Theme.Material.Light.NoActionBar.Fullscreen">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
